{
  "scheme_id": "pmjay",
  "name": "Ayushman Bharat PM-JAY",
  "authority": "National Health Authority",
  "version": "HBP 2022",
  "guidelines_version": "2026",
  "model": "trust_or_insurance_or_hybrid",

  "coverage": {
    "sum_insured_inr": 500000,
    "basis": "family_floater",
    "period": "annual",
    "family_size_cap": null,
    "age_limit": null,
    "ped_waiting_period_days": 0,
    "pre_authorization_required": true,
    "covers": ["secondary_inpatient", "tertiary_inpatient", "daycare"],
    "excludes_opd": true,
    "pre_hosp_days": 3,
    "post_hosp_days": 15,
    "senior_70plus_shared_topup_inr": 500000,
    "senior_70plus_card_name": "Ayushman Vay Vandana Card"
  },

  "pricing": {
    "model": "fixed_package_rate",
    "balance_billing_allowed": false,

    "copay": {
      "allowed": false,
      "exceptions": ["exceeds_wallet_balance", "exceeds_ceiling"],
      "requires_both_consents": true,
      "approved_by": "CEO_SHA",
      "not_allowed_for": ["usp", "exclusion_category"]
    },

    "state_rate_modification_pct": {
      "max_increase": 10,
      "max_decrease": 10,
      "above_110pct_borne_by_state": true
    },

    "city_tier_uplift_pct": {
      "surgical": {
        "tier1": 25,
        "tier2": 17,
        "tier3": 0,
        "tertiary_add": 25
      },
      "medical": {
        "tier1": 15,
        "tier2": 15,
        "tier3": 0,
        "tertiary_add": 10
      },
      "_note": "Uplifts are compounded, not additive. tertiary_add applies on top of tier uplift."
    },

    "quality_incentives_pct": {
      "bronze": 5,
      "nabh_entry": 10,
      "nabh_full": 15,
      "nqas": 15,
      "aspirational_district": 10,
      "_note": "Only one quality incentive at a time. Can combine quality + geo. Compounded."
    },
    "incentive_stacking": "compounded",
    "incentive_applies_to_implant": false,
    "incentive_applies_to_stratification_delta": true,

    "per_day_bed_rates_inr": {
      "ward": 2100,
      "hdu": 3300,
      "icu_no_vent": 8500,
      "icu_vent": 9000
    },

    "multi_procedure_rule_pct": [100, 50, 25],
    "_multi_procedure_note": "Sorted by rate descending. Implant costs not subject to deduction.",

    "combination_rules": {
      "surgical_plus_surgical": "100_50_25",
      "surgical_plus_medical_nonperday": "full_each",
      "surgical_plus_perday_medical": "not_allowed_same_preauth",
      "medical_plus_medical_nonperday": "full_each",
      "perday_plus_perday": "not_allowed_same_preauth",
      "addon_with_primary": "full_100_no_deduction",
      "_surgical_nonperday_exception": "SHA can approve surgical+perday in exceptional cases"
    },

    "special_case_payment_pct": {
      "lama_before_surgery": {
        "type": "per_day_medical",
        "pct": 100,
        "basis": "full_days_admitted_per_ward_category",
        "notify_sha_hours": 24
      },
      "lama_after_surgery": {
        "type": "flat_pct",
        "pct": 75,
        "docs_required": ["daily_case_sheets", "ot_notes"]
      },
      "death_before_surgery": {
        "type": "per_day_medical",
        "pct": 100,
        "basis": "full_days_admitted_per_ward_category"
      },
      "death_on_table": {
        "type": "flat_pct",
        "pct": 75
      },
      "death_after_surgery": {
        "type": "flat_pct",
        "pct": 100,
        "requires_mortality_audit": true
      },
      "death_within_24h_preauth_approved": {
        "type": "flat_pct",
        "pct": 50,
        "requires_mortality_audit": true
      },
      "death_within_24h_preauth_pending": {
        "type": "flat_pct",
        "pct": 50,
        "basis": "first_day_only"
      },
      "death_within_24h_no_preauth": {
        "type": "flat_pct",
        "pct": 0
      },
      "referral_before_pac": {
        "referring_pct": "per_day_medical_full_days",
        "receiving_pct": 100
      },
      "referral_after_pac_surgery_abandoned": {
        "referring_pct": 15,
        "receiving_pct": 85,
        "receiving_needs_preauth": true
      },
      "referral_after_surgery_complication": {
        "referring_pct": 75,
        "receiving_pct": 100,
        "receiving_needs_preauth": true
      },
      "referral_to_non_empanelled": {
        "receiving_pct": 0
      }
    },

    "final_price_formula": "( procedure_price + stratification_delta ) x level_multiplier x tier_multiplier x accreditation_multiplier x geo_multiplier + implant_cost_flat"
  },

  "usp": {
    "name": "Unspecified Surgical Package",
    "applies_to": "surgical_only",
    "conditions": ["not_in_hbp_master", "denial_of_care_would_result"],
    "approver": "CEO_SHA",
    "max_inr": 500000,
    "decision_hours": 48,
    "auto_reject_on_timeout": true,
    "review_path": ["PPD", "SHA_Medical_Committee", "CEO_SHA"],
    "rate_basis": "closest_matching_hbp_or_cghs",
    "not_allowed_for": [
      "medical_packages",
      "individual_drugs_or_diagnostics",
      "government_reserved_packages",
      "exclusion_category",
      "aesthetic_treatments",
      "implant_removal_same_policy_if_covered"
    ],
    "copay_eligible": false
  },

  "exclusions": [
    {
      "id": "opd_no_hospitalisation",
      "description": "Conditions that do not require hospitalisation and can be treated under OPD",
      "exceptions": [
        "Pre-hospitalisation expenses up to 3 days",
        "Post-hospitalisation expenses up to 15 days"
      ]
    },
    {
      "id": "dental_non_trauma",
      "description": "Dental treatment corrective, prosthetic, cosmetic, cavity filling, root canal, periodontal, implants",
      "exceptions": [
        "Treatment arising from trauma or injury requiring hospitalisation for bone treatment",
        "Neoplasia or tumour or cyst requiring hospitalisation for bone treatment"
      ]
    },
    {
      "id": "infertility_art",
      "description": "Assisted reproductive techniques and infertility-related procedures",
      "exceptions": ["Procedures listed in the National HBP package master"]
    },
    {
      "id": "vaccination",
      "description": "Vaccination and immunisation"
    },
    {
      "id": "cosmetic_aesthetic",
      "description": "Cosmetic and aesthetic procedures: ageing face/body surgery, tattoo removal, augmentation, fat grafting, neck lift, aesthetic rhinoplasty",
      "exceptions": [
        "Correction of significant deformity from accidental injury or trauma",
        "Congenital anomaly with significant functional impairment",
        "Medically necessary with functional purpose"
      ]
    },
    {
      "id": "circumcision_under_2",
      "description": "Circumcision for children under 2 years of age",
      "exceptions": [
        "Required for treatment of a disease not excluded hereunder",
        "Necessitated due to accident"
      ]
    },
    {
      "id": "persistent_vegetative_state",
      "description": "Persistent Vegetative State — unresponsive, no higher brain function, kept alive by medical intervention only"
    },
    {
      "id": "alcohol_drug_overdose",
      "description": "Drug rehabilitation, alcohol de-addiction",
      "exceptions": [
        "Life-threatening: treatment provided until patient condition stabilises (suicide attempt or accident due to excess alcohol)"
      ]
    }
  ],

  "enhancement": {
    "applicable_to": "per_day_medical_management_only",
    "private_max_days_per_request": 2,
    "public_max_days_per_request": 5,
    "ne_states_and_islands_private_max_days": 5,
    "ne_states": ["Assam", "Tripura", "Arunachal Pradesh", "Meghalaya", "Nagaland", "Mizoram", "Sikkim"],
    "island_uts": ["Andaman and Nicobar Islands", "Lakshadweep"]
  },

  "backdated_booking": {
    "private_max_days": 2,
    "public_max_days": 5,
    "ne_states_and_islands_private_max_days": 5
  },

  "aadhaar_auth": {
    "mandatory_at_admission": true,
    "mandatory_at_discharge": true,
    "modes": ["face", "fingerprint", "iris"],
    "exemptions": ["unconscious", "emergency", "biometric_failure_technical"],
    "exemption_certifier": "Medical_Superintendent_via_MS_Login",
    "child_under_5_relaxation": "parent_ayushman_card_plus_parent_biometric"
  },

  "slas": {
    "preauth_decision_hours": 6,
    "preauth_scheduler_window": null,
    "preauth_deemed_approved_on_timeout": true,
    "preauth_max_queries": 2,
    "preauth_query_response_hours": 2,
    "usp_decision_hours": 48,
    "usp_auto_reject_on_timeout": true,
    "claim_submission_days_private": null,
    "claim_submission_days_public": null,
    "claim_max_queries": 2,
    "nafu_fraud_scan_hours": 24,
    "deduction_triggers_mac_review_above_pct": 20,
    "mac_decision_days": null,
    "claim_payment_days": 15,
    "portability_claim_payment_days": null,
    "lama_dama_notify_sha_hours_private": 24,
    "lama_dama_notify_sha_hours_public": 72,
    "sos_grievance_hours": 5,
    "non_sos_grievance_days": 15
  },

  "it_systems": {
    "beneficiary_identification": "BIS",
    "transactions": "TMS",
    "empanelment": "HEM",
    "grievance": "CGRMS",
    "anti_fraud": "NAFU",
    "hospital_helpline": "14413"
  },

  "adjudication_roles": {
    "preauth_reviewer": "PPD",
    "claim_completeness": "CEX",
    "claim_clinical": "CPD",
    "finance_approval": "ACO",
    "final_payer": "SHA_or_IC",
    "fraud_desk_audit": "SAFU_Doctor",
    "fraud_field_investigation": "SHA_AFO",
    "audit_committee": "MAC",
    "claims_review_committee": "CRC"
  },

  "source_refs": {
    "coverage": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §1.1–1.3",
    "pricing.city_tier_uplift_pct": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §5.3.1, Table 3",
    "pricing.quality_incentives_pct": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §5.3, Table 2",
    "pricing.per_day_bed_rates_inr": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §3.2.1",
    "pricing.multi_procedure_rule_pct": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §3.10.1",
    "pricing.combination_rules": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §3.10.1–3.10.5",
    "pricing.special_case_payment_pct": "Claim_Adjudication_Guidelines_ef66003cc7.pdf §8.1–8.3, Figures 13–16; National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §6.1–6.3, Figures 3–5",
    "pricing.copay": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §5.6, Annexure 10",
    "usp": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §3.11.1–3.11.2, Annexures 4–5",
    "exclusions": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §3.11.1.l, Annexure 6",
    "enhancement": "National_Health_Benefits_Packages_Guidelines_fceb804a58.pdf §1.4.14, §3.9",
    "backdated_booking": "Claim_Adjudication_Guidelines_ef66003cc7.pdf §10.1, Annexure 24",
    "aadhaar_auth": "Claim_Adjudication_Guidelines_ef66003cc7.pdf §4.4.A.i, Annexure 9",
    "slas": "Claim_Adjudication_Guidelines_ef66003cc7.pdf §4.4–4.6, §10.1",
    "adjudication_roles": "Claim_Adjudication_Guidelines_ef66003cc7.pdf §4.2, Table 2"
  }
}
